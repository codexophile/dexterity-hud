<UserControl x:Class="DexterityHud.Controls.KeyboardKey"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="72"
             Height="64">
  <Border CornerRadius="12"
          Padding="10"
          BorderThickness="1.5"
          BorderBrush="#2F3948"
          Background="{Binding FingerColor, ElementName=Root}">
    <Grid>
      <TextBlock Text="{Binding PrimaryText, ElementName=Root}"
                 Foreground="White"
                 FontSize="20"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top" />
      <TextBlock Text="{Binding SecondaryText, ElementName=Root}"
                 Foreground="#DCE7F3"
                 Opacity="0.95"
                 FontSize="20"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom" />
    </Grid>
  </Border>
</UserControl>